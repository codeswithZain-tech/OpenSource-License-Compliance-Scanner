# Backend environment variables (copy to .env on your host)

# Required for GitHub API requests
GITHUB_TOKEN=

# Required in production
SECRET_KEY=

# Production toggles
DEBUG=False
REQUIRE_AUTH=True

# Hosts allowed by Django (comma-separated)
# Example: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

