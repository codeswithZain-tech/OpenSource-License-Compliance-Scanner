# Backend environment variables (copy to .env for local dev, or set in Railway dashboard)

# Required for GitHub API requests
GITHUB_TOKEN=ghp_your_token_here

# Required in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Production toggles
DEBUG=False
REQUIRE_AUTH=True
CORS_ALLOW_ALL_ORIGINS=False
# For Railway: set this to your Vercel frontend URL (no trailing slash)
# Example: CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Hosts allowed by Django (comma-separated)
# Railway auto-injects RAILWAY_HOSTNAME — no need to add it here
ALLOWED_HOSTS=127.0.0.1,localhost
